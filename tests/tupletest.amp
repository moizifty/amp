operator +(a: s1, b: s1) : s1
{
    return s1{(90, 0, 69)};
}

operator *(a: s1, b: s1) : s1
{
    _a := a.a[0] * b.a[0];
    _b := a.a[1] * b.a[1];
    _c := a.a[2] * b.a[2];
    return s1{(_a, _b, _c)};
}

operator -(a: s1) : s1
{
    _a := a.a[0];
    _b := a.a[1];
    _c := a.a[2];
    return s1{(-_a, -_b, -_c)};
}

