calc(str: string) : i64
{
    inpBuffer = cast(*i8) str.data;
    ch = ' ';
    tok = lex();
    e := expr();
    ret := evalExpr(e);

    if(arena != null) -> cstd::free(arena);
    arena = null;

    return ret;
}

advanceLexCh()
{
    ch = @inpBuffer;
    inpBuffer = inpBuffer + 1;
}

lex() : Tok
{
    while(ch == ' ')
    {
        advanceLexCh();
    }

    t: Tok = {};

    if(ch == '+')
    {
        t.kind = TokKind.Add;
        t.lexeme[0] = ch;
    }
    else if(ch == '-')
    {
        t.kind = TokKind.Minus;
        t.lexeme[0] = ch;
    }
    else if(ch == '*')
    {
        t.kind = TokKind.Mult;
        t.lexeme[0] = ch;
    }
    else if(ch == '/')
    {
        t.kind = TokKind.Div;
        t.lexeme[0] = ch;
    }
    else if(ch == '(')
    {
        t.kind = TokKind.OpenParen;
        t.lexeme[0] = ch;
    }
    else if(ch == ')')
    {
        t.kind = TokKind.CloseParen;
        t.lexeme[0] = ch;
    }
    else if(cstd::isdigit(ch))
    {
        lexemeLen := 0;
        t.lexeme[lexemeLen] = ch;
        lexemeLen = lexemeLen + 1;

        advanceLexCh();

        while(cstd::isdigit(ch))
        {
            t.lexeme[lexemeLen] = ch;

            lexemeLen = lexemeLen + 1;

            advanceLexCh();
        }

        t.kind = TokKind.LitInt;
        return t;
    }
    else if(ch == '\0')
    {
        t.kind = TokKind.End;
        return t;
    }
    else
    {
        t.kind = TokKind.Invalid;
        t.lexeme[0] = ch;
    }

    advanceLexCh();

    return t;
}

expr() : *Expr
{
    e: *Expr = multTerm();

    while((tok.kind == TokKind.Add) || (tok.kind == TokKind.Minus))
    {
        op: Tok = tok;
        tok = lex();
        l := e;

        e = memarena(#Expr.size);

        @e = Expr{ExprBinary{l = l, op = op.kind, r = multTerm()}};
    }

    return e;
}

multTerm() : *Expr
{
    e: *Expr = factor();

    while((tok.kind == TokKind.Mult) || (tok.kind == TokKind.Div) || (tok.kind == TokKind.OpenParen))
    {
        op: Tok = tok;
        isImplicitMult := (op.kind == TokKind.OpenParen);

        if(!isImplicitMult) -> tok = lex();

        l := e;
        e = memarena(#Expr.size);
        @e = Expr{ExprBinary{l = l, op = op.kind, r = factor()}};
    }
    return e;
}

factor() : *Expr
{
    e: *Expr = null;

    if(tok.kind == TokKind.LitInt)
    {
        e = memarena(#Expr.size);
        @e = Expr{tok};
        tok = lex();
    }
    else if(tok.kind == TokKind.OpenParen)
    {
        tok = lex();
        e = expr();

        if(tok.kind == TokKind.CloseParen) -> tok = lex();
        else
        {
            io::printLn("Expected matching paren");
        }
    }
    else
    {
        io::printLn("Unexpected token '%'", tok.toString());
        tok = lex();
    }

    return e;
}

evalExpr(e: *Expr) : i64
{
    return matchx(@e)
    {
        Expr.Lit(l) ->
        {
            av := l.lexeme;
            cstd::atol(cast(* i8)l.lexeme);
        }
        Expr.Binary(b) ->
        {
            l := evalExpr(b.l);
            r := evalExpr(b.r);

            matchx(b.op)
            {
                TokKind.Add ->-> l + r;
                TokKind.Minus ->-> l - r;
                TokKind.Mult, TokKind.OpenParen ->-> l * r;
                TokKind.Div ->-> l / r;
            };
        }
    };
}