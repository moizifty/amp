import cstd
import std::io

enum TokKind
{
    Add;
    Minus;
    Mult;
    Div;
    OpenParen;
    CloseParen;
    LitInt;
    LitFloat;
    End;

    Invalid;
}

struct Tok
{
    kind: TokKind;
    lexeme: [256]i8 = [256]{0};
}

method Tok
{
    [thisPtr]
    toString() : string
    {
        if(this.kind == TokKind.End) -> return "End of Input";

        return {data = cast(* void) this.lexeme, len = this.lexeme.len};
    }
}

enum ExprKind
{
    Binary;
    Lit;
}

union Expr(ExprKind)
{
    Binary: ExprBinary;
    Lit: Tok;
}

struct ExprBinary
{
    l: *Expr;
    op: TokKind;
    r: *Expr;
}

inpBuffer: *i8;
ch: i8 = ' ';

tok: Tok;

totalArenaSize := 100000;
arena := null;
currOccupied: i64 = 0;

memarena(size: i64) : *void
{
    if(arena == null)
    {
        //this is bad but its only an example
        arena = cstd::malloc(totalArenaSize);
    }

    if(currOccupied + size > totalArenaSize)
    {
        io::printLn("Max arena space reached");
        return null;
    }

    toRet := arena + currOccupied;
    currOccupied = currOccupied + size;
    return toRet;
}

