import std::io
import w = os::windows

main()
{
    ret := w::MessageBoxA(null, "hiii".data, "whatsup".data, 1 | 2);

    if(ret == 6)
    {
        io::print("hiiii");
    }

    d := "sdsd";
    c: *string = null;
    n := c?.data else cast(*ui8) *d;

    io::print("sds\n");
    io::print("%", n);
}